{
  "name": "homehub",
  "version": "0.1.0",
  "private": true,
  "description": "HomeHub monorepo foundation.",
  "scripts": {
    "build": "npm run build --workspace @homehub/web",
    "dev:web": "npm run dev --workspace @homehub/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview:web": "npm run preview --workspace @homehub/web",
    "test": "echo \"No tests configured yet\""
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0"
  }
}
